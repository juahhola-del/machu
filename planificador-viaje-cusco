    const STATE = {
      history: [],
      historyIndex: -1,
      plan: null
    };

    function selectedMainItems() {
      return Array.from(document.querySelectorAll('.checkbox-grid input[type="checkbox"]:checked')).map(el => el.value);
    }

    function getBaseInputs() {
      return {
        days: parseInt(document.getElementById("days").value, 10),
        style: document.getElementById("style").value,
        budget: document.getElementById("budget").value,
        arrival: document.getElementById("arrival").value || null,
        selected: selectedMainItems()
      };
    }

    function clone(obj) {
      return JSON.parse(JSON.stringify(obj));
    }

    function budgetOrder(budget) {
      if (budget === "economico") return ["economico", "balanceado", "premium"];
      if (budget === "premium") return ["premium", "balanceado", "economico"];
      return ["balanceado", "economico", "premium"];
    }

    function effortWeight(effort) {
      return effort === "alto" ? 3 : effort === "medio" ? 2 : 1;
    }

    function chooseVariant(activity, budget) {
      const order = budgetOrder(budget);
      for (const key of order) {
        if (activity.variants[key]) {
          return { key, ...activity.variants[key] };
        }
      }
      const firstKey = Object.keys(activity.variants)[0];
      return { key: firstKey, ...activity.variants[firstKey] };
    }

    function chooseTransfer(transferId, budget) {
      const transfer = TRANSFERS[transferId];
      if (!transfer) return null;
      const order = budgetOrder(budget);
      for (const key of order) {
        if (transfer.options[key]) {
          return { key, ...transfer.options[key], transferId, transferLabel: transfer.label };
        }
      }
      const firstKey = Object.keys(transfer.options)[0];
      return { key: firstKey, ...transfer.options[firstKey], transferId, transferLabel: transfer.label };
    }

    function formatUsd(value) {
      return new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }).format(value);
    }

    function humanHours(value) {
      return `${(Math.round(value * 10) / 10).toString().replace(".0", "")} h`;
    }

    function setTimeWindow(day, start, end) {
      day.startTime = start;
      day.endTime = end;
    }

    function createDay(dayNumber) {
      return {
        dayNumber,
        title: `Día ${dayNumber}`,
        subtitle: "",
        image: "/planificador/cusco.jpg",
        location: "cusco",
        lodging: "cusco",
        activityId: null,
        activityName: "Día flexible",
        selectedVariantKey: null,
        selectedVariantLabel: null,
        selectedTransferId: null,
        selectedTransferKey: null,
        selectedTransferLabel: null,
        transferHours: 0,
        activityHours: 0,
        freeHours: 0,
        costUsd: 0,
        meals: [],
        recommendation: "Día flexible para descanso o ajuste de ruta.",
        warning: "",
        effort: "bajo",
        startTime: "09:00",
        endTime: "18:00"
      };
    }

    function buildDayFromActivity(day, activityId, budget, extra = {}) {
      const activity = ACTIVITIES[activityId];
      if (!activity) return day;
      const variant = chooseVariant(activity, budget);

      day.activityId = activity.id;
      day.activityName = activity.name;
      day.selectedVariantKey = variant.key;
      day.selectedVariantLabel = variant.label;
      day.subtitle = variant.label;
      day.image = activity.image;
      day.location = activity.location;
      day.activityHours = variant.activityHours || 0;
      day.transferHours = extra.transferHours || 0;
      day.costUsd = (variant.costUsd || 0) + (extra.transferCostUsd || 0);
      day.meals = variant.meals || [];
      day.effort = activity.effort;
      day.recommendation = buildRecommendation(activity, variant, extra);
      day.warning = buildWarning(activity, variant, day.dayNumber, extra.style, extra);
      day.selectedTransferId = extra.transferId || null;
      day.selectedTransferKey = extra.transferKey || null;
      day.selectedTransferLabel = extra.transferLabel || null;
      day.lodging = extra.lodging || day.location;
      setTimeWindow(day, extra.startTime || activity.baseStart, extra.endTime || activity.baseEnd);

      const totalUsed = day.activityHours + day.transferHours;
      day.freeHours = Math.max(0, 14 - totalUsed);

      return day;
    }

    function buildRecommendation(activity, variant, extra) {
      const bits = [variant.note];
      if (extra.transferLabel) bits.push(`Traslado: ${extra.transferLabel}.`);
      if (extra.transferNote) bits.push(extra.transferNote);
      if ((variant.meals || []).length) {
        bits.push(`Incluye ${variant.meals.join(", ")}.`);
      } else {
        bits.push("No incluye comida, así que conviene llevar snack o presupuesto para ese bloque.");
      }
      if (extra.lodging && LOCATIONS[extra.lodging]) {
        bits.push(`Noche recomendada en ${LOCATIONS[extra.lodging].name}.`);
      }
      return bits.join(" ");
    }

    function buildWarning(activity, variant, dayNumber, style, extra) {
      const warnings = [];
      if (dayNumber === 1 && ["humantay", "vinicunca", "palccoyo"].includes(activity.id)) {
        warnings.push("No conviene poner altura fuerte el primer día.");
      }
      if (style === "relajado" && activity.effort === "alto") {
        warnings.push("Se siente intenso para un viaje relajado.");
      }
      if (!(variant.meals || []).length) {
        warnings.push("No incluye comida.");
      }
      if ((extra.transferHours || 0) >= 5) {
        warnings.push("El traslado es largo y te quita tiempo útil.");
      }
      return warnings.join(" ");
    }

    function createArrivalDay(day, inputs) {
      const arrivalHour = inputs.arrival ? new Date(inputs.arrival).getHours() : 12;
      const budget = inputs.budget;
      const variant = ACTIVITIES.acclimatization.variants[budget];

      day.activityId = "acclimatization";
      day.activityName = "Aclimatación en Cusco";
      day.selectedVariantKey = budget;
      day.selectedVariantLabel = variant.label;
      day.subtitle = variant.label;
      day.image = ACTIVITIES.acclimatization.image;
      day.location = "cusco";
      day.lodging = "cusco";
      day.activityHours = variant.activityHours;
      day.transferHours = 0.5;
      day.costUsd = variant.costUsd;
      day.meals = [];
      day.effort = "bajo";
      day.startTime = arrivalHour >= 15 ? "16:00" : "14:00";
      day.endTime = "20:00";
      day.freeHours = Math.max(0, 14 - (day.activityHours + day.transferHours));
      day.recommendation = `${variant.note} Primer día ideal para caminar suave, hidratarte y dormir temprano.`;
      day.warning = "Evita tours de altura este día.";
      return day;
    }

    function buildInitialBlocks(inputs) {
      const days = Array.from({ length: inputs.days }, (_, idx) => createDay(idx + 1));
      if (days.length) {
        createArrivalDay(days[0], inputs);
      }

      const selected = new Set(inputs.selected);

      if (selected.has("machu_picchu")) {
        if (inputs.days >= 2) {
          const transfer1 = chooseTransfer("cusco_to_ollantaytambo", inputs.budget);
          const transfer2 = chooseTransfer("ollantaytambo_to_aguas", inputs.budget);
          buildDayFromActivity(days[1], "aguas_free", inputs.budget, {
            style: inputs.style,
            transferId: "cusco_to_ollantaytambo",
            transferKey: transfer1.key,
            transferLabel: `${transfer1.transferLabel} • ${transfer1.label}`,
            transferHours: transfer1.durationHours + transfer2.durationHours,
            transferCostUsd: transfer1.costUsd + transfer2.costUsd,
            transferNote: `${transfer1.note} Luego conectas con ${transfer2.label}.`,
            lodging: "aguas_calientes",
            startTime: "07:00",
            endTime: "20:00"
          });
        }

        if (inputs.days >= 3) {
          const transfer3 = chooseTransfer("aguas_to_machu", inputs.budget);
          buildDayFromActivity(days[2], "machu_picchu", inputs.budget, {
            style: inputs.style,
            transferId: "aguas_to_machu",
            transferKey: transfer3.key,
            transferLabel: `${transfer3.transferLabel} • ${transfer3.label}`,
            transferHours: transfer3.durationHours,
            transferCostUsd: transfer3.costUsd,
            transferNote: transfer3.note,
            lodging: "cusco",
            startTime: "05:30",
            endTime: "17:00"
          });
        }
      }

      if (selected.has("valle_sagrado")) {
        const slot = findFreeDayIndex(days, 1);
        if (slot !== -1) {
          buildDayFromActivity(days[slot], "valle_sagrado", inputs.budget, {
            style: inputs.style,
            lodging: "cusco"
          });
        }
      }

      if (selected.has("humantay")) {
        const slot = findFreeDayIndex(days, 1);
        if (slot !== -1) {
          buildDayFromActivity(days[slot], "humantay", inputs.budget, {
            style: inputs.style,
            lodging: "cusco"
          });
        }
      }

      if (selected.has("vinicunca")) {
        const slot = findFreeDayIndex(days, 2);
        if (slot !== -1) {
          buildDayFromActivity(days[slot], "vinicunca", inputs.budget, {
            style: inputs.style,
            lodging: "cusco"
          });
        }
      }

      if (selected.has("palccoyo")) {
        const slot = findFreeDayIndex(days, 1);
        if (slot !== -1) {
          buildDayFromActivity(days[slot], "palccoyo", inputs.budget, {
            style: inputs.style,
            lodging: "cusco"
          });
        }
      }

      if (selected.has("santa_teresa")) {
        const slot = findFreeDayIndex(days, 1);
        if (slot !== -1) {
          const transfer = chooseTransfer("cusco_to_santa_teresa", inputs.budget);
          const local = chooseTransfer("santa_teresa_to_cocalmayo", inputs.budget);
          buildDayFromActivity(days[slot], "santa_teresa", inputs.budget, {
            style: inputs.style,
            transferId: "cusco_to_santa_teresa",
            transferKey: transfer.key,
            transferLabel: `${transfer.transferLabel} • ${transfer.label}`,
            transferHours: transfer.durationHours + local.durationHours,
            transferCostUsd: transfer.costUsd + local.costUsd,
            transferNote: `${transfer.note} Luego conectas con ${local.label}.`,
            lodging: "santa_teresa",
            startTime: "08:00",
            endTime: "20:00"
          });
        }
      }

      if (selected.has("cusco_city")) {
        const slot = findFreeDayIndex(days, 0);
        if (slot !== -1) {
          buildDayFromActivity(days[slot], "cusco_city", inputs.budget, {
            style: inputs.style,
            lodging: "cusco"
          });
        }
      }

      finalizeFlexibleDays(days);
      return days;
    }

    function findFreeDayIndex(days, startIndex) {
      for (let i = startIndex; i < days.length; i++) {
        if (!days[i].activityId) return i;
      }
      return -1;
    }

    function finalizeFlexibleDays(days) {
      for (const day of days) {
        if (!day.activityId) {
          day.activityId = "free";
          day.activityName = "Día flexible";
          day.subtitle = "Descanso / ajuste libre";
          day.image = "/planificador/cusco.jpg";
          day.location = "cusco";
          day.lodging = "cusco";
          day.activityHours = 2;
          day.transferHours = 0;
          day.costUsd = 0;
          day.meals = [];
          day.effort = "bajo";
          day.startTime = "10:00";
          day.endTime = "18:00";
          day.freeHours = 12;
          day.recommendation = "Úsalo para descansar, mover actividades o sumar una experiencia suave.";
          day.warning = "";
        }
      }
    }

    function createPlan() {
      const inputs = getBaseInputs();
      const days = buildInitialBlocks(inputs);
      return { meta: inputs, days };
    }

    function saveHistory(plan) {
      const snapshot = clone(plan);
      STATE.history = STATE.history.slice(0, STATE.historyIndex + 1);
      STATE.history.push(snapshot);
      STATE.historyIndex = STATE.history.length - 1;
      STATE.plan = snapshot;
    }

    function computeSummary(plan) {
      let totalCost = 0;
      let totalTransfer = 0;
      let totalActivity = 0;
      let totalFree = 0;
      let totalMeals = 0;

      for (const day of plan.days) {
        totalCost += day.costUsd || 0;
        totalTransfer += day.transferHours || 0;
        totalActivity += day.activityHours || 0;
        totalFree += day.freeHours || 0;
        totalMeals += (day.meals || []).length;
      }

      return { totalCost, totalTransfer, totalActivity, totalFree, totalMeals };
    }

    function planEffort(plan) {
      const weights = plan.days.map(d => effortWeight(d.effort || "bajo"));
      const avg = weights.length ? weights.reduce((a, b) => a + b, 0) / weights.length : 1;
      if (avg >= 2.5) return { label: "Exigencia alta", cls: "red" };
      if (avg >= 1.8) return { label: "Exigencia media", cls: "orange" };
      return { label: "Exigencia suave", cls: "green" };
    }

    function renderDay(day) {
      const activityOptions = [
        { id: "free", name: "Día flexible" },
        ...Object.values(ACTIVITIES)
          .filter(a => a.id !== "acclimatization")
          .map(a => ({ id: a.id, name: a.name }))
      ].map(a => `<option value="${a.id}" ${day.activityId === a.id ? "selected" : ""}>${a.name}</option>`).join("");

      let variantOptions = `<option value="">Sin variantes</option>`;
      if (ACTIVITIES[day.activityId]) {
        variantOptions = Object.entries(ACTIVITIES[day.activityId].variants || {}).map(([key, value]) => {
          const impact = ` • ${formatUsd(value.costUsd)} • ${humanHours(value.activityHours)}`;
          return `<option value="${key}" ${day.selectedVariantKey === key ? "selected" : ""}>${value.label}${impact}</option>`;
        }).join("");
      }

      let transferOptions = `<option value="">Sin traslado editable</option>`;
      if (day.selectedTransferId && TRANSFERS[day.selectedTransferId]) {
        transferOptions = Object.entries(TRANSFERS[day.selectedTransferId].options).map(([key, value]) => {
          const impact = ` • ${formatUsd(value.costUsd)} • ${humanHours(value.durationHours)}`;
          return `<option value="${key}" ${day.selectedTransferKey === key ? "selected" : ""}>${value.label}${impact}</option>`;
        }).join("");
      }

      const mealText = day.meals && day.meals.length ? day.meals.join(", ") : "No incluidas";
      const effortClass = day.effort === "alto" ? "red" : day.effort === "medio" ? "orange" : "green";
      const locationName = LOCATIONS[day.location]?.name || day.location;
      const lodgingName = LOCATIONS[day.lodging]?.name || day.lodging;

      return `
        <div class="card day-card">
          <div>
            <img class="day-photo" src="${day.image}" alt="${day.activityName}" />
          </div>

          <div class="day-body">
            <div class="day-head">
              <div class="day-title">
                <div class="eyebrow">Itinerario</div>
                <h3>${day.title}: ${day.activityName}</h3>
                <p>${day.subtitle || "Sin variante definida"} • ${locationName}</p>
              </div>
              <span class="pill ${effortClass}">${day.effort}</span>
            </div>

            <div class="time-box">
              <b>Inicio:</b> ${day.startTime} • <b>Término:</b> ${day.endTime} •
              <b>Horas de traslado:</b> ${humanHours(day.transferHours || 0)} •
              <b>Horas libres:</b> ${humanHours(day.freeHours || 0)}
            </div>

            <div class="line"><b>Costo estimado del día:</b> ${formatUsd(day.costUsd || 0)} • <b>Comidas incluidas:</b> ${mealText} • <b>Noche sugerida:</b> ${lodgingName}</div>

            ${day.selectedTransferLabel ? `<div class="info-note"><b>Traslado actual:</b> ${day.selectedTransferLabel}</div>` : ""}
            <div class="recommendation">${day.recommendation || "Sin recomendación."}</div>
            ${day.warning ? `<div class="warning">${day.warning}</div>` : ""}

            <div class="actions-row">
              <div class="selector-card">
                <h4>Cambiar actividad</h4>
                <select data-swap-activity data-day="${day.dayNumber}">
                  ${activityOptions}
                </select>
              </div>

              <div class="selector-card">
                <h4>Cambiar variante (valor y tiempo)</h4>
                <select data-change-variant data-day="${day.dayNumber}">
                  ${variantOptions}
                </select>
              </div>

              <div class="selector-card">
                <h4>Cambiar transporte (valor y tiempo)</h4>
                <select data-change-transfer data-day="${day.dayNumber}">
                  ${transferOptions}
                </select>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    function renderPlan(plan) {
      document.getElementById("result-section").classList.remove("hidden");

      const summary = computeSummary(plan);
      document.getElementById("summary-cost").textContent = formatUsd(summary.totalCost);
      document.getElementById("summary-transfer").textContent = humanHours(summary.totalTransfer);
      document.getElementById("summary-activities").textContent = humanHours(summary.totalActivity);
      document.getElementById("summary-free").textContent = humanHours(summary.totalFree);
      document.getElementById("summary-meals").textContent = String(summary.totalMeals);

      const effort = planEffort(plan);
      const effortBadge = document.getElementById("effort-badge");
      effortBadge.textContent = effort.label;
      effortBadge.className = `pill ${effort.cls}`;

      const badge = document.getElementById("plan-badge");
      badge.textContent = `Plan ${plan.meta.budget} • ${plan.meta.style} • ${plan.meta.days} días`;
      badge.className = "pill blue";

      const output = document.getElementById("plan-output");
      output.innerHTML = plan.days.map(day => renderDay(day)).join("");

      output.querySelectorAll("[data-change-variant]").forEach(el => {
        el.addEventListener("change", (e) => updateDayVariant(parseInt(e.target.dataset.day, 10), e.target.value));
      });

      output.querySelectorAll("[data-change-transfer]").forEach(el => {
        el.addEventListener("change", (e) => updateDayTransfer(parseInt(e.target.dataset.day, 10), e.target.value));
      });

      output.querySelectorAll("[data-swap-activity]").forEach(el => {
        el.addEventListener("change", (e) => updateDayActivity(parseInt(e.target.dataset.day, 10), e.target.value));
      });
    }

    function applyVariantToDay(day, activityId, variantKey, style) {
      if (activityId === "free" || !ACTIVITIES[activityId]) {
        day.activityId = "free";
        day.activityName = "Día flexible";
        day.subtitle = "Descanso / ajuste libre";
        day.image = "/planificador/cusco.jpg";
        day.location = "cusco";
        day.lodging = "cusco";
        day.selectedVariantKey = null;
        day.selectedVariantLabel = null;
        day.selectedTransferId = null;
        day.selectedTransferKey = null;
        day.selectedTransferLabel = null;
        day.transferHours = 0;
        day.activityHours = 2;
        day.costUsd = 0;
        day.meals = [];
        day.effort = "bajo";
        day.startTime = "10:00";
        day.endTime = "18:00";
        day.freeHours = 12;
        day.recommendation = "Úsalo para mover actividades, descansar o explorar con calma.";
        day.warning = "";
        return;
      }

      const activity = ACTIVITIES[activityId];
      const variant = activity.variants[variantKey] ? { key: variantKey, ...activity.variants[variantKey] } : chooseVariant(activity, STATE.plan.meta.budget);

      const currentTransfer = day.selectedTransferId && TRANSFERS[day.selectedTransferId]
        ? TRANSFERS[day.selectedTransferId].options[day.selectedTransferKey || STATE.plan.meta.budget]
        : null;

      day.activityId = activity.id;
      day.activityName = activity.name;
      day.subtitle = variant.label;
      day.image = activity.image;
      day.location = activity.location;
      day.selectedVariantKey = variant.key;
      day.selectedVariantLabel = variant.label;
      day.activityHours = variant.activityHours || 0;
      day.meals = variant.meals || [];
      day.effort = activity.effort;
      day.costUsd = (variant.costUsd || 0) + (currentTransfer?.costUsd || 0);
      day.transferHours = currentTransfer?.durationHours || 0;
      day.freeHours = Math.max(0, 14 - (day.activityHours + day.transferHours));
      day.recommendation = buildRecommendation(activity, variant, {
        transferLabel: day.selectedTransferLabel,
        transferNote: currentTransfer?.note,
        lodging: day.lodging
      });
      day.warning = buildWarning(activity, variant, day.dayNumber, style, { transferHours: day.transferHours });
      day.startTime = activity.baseStart;
      day.endTime = activity.baseEnd;
    }

    function applyTransferToDay(day, transferKey, style) {
      if (!day.selectedTransferId || !TRANSFERS[day.selectedTransferId]) return;

      const transfer = TRANSFERS[day.selectedTransferId];
      const option = transfer.options[transferKey];
      if (!option) return;

      day.selectedTransferKey = transferKey;
      day.selectedTransferLabel = `${transfer.label} • ${option.label}`;
      day.transferHours = option.durationHours;
      day.costUsd = recalcDayCost(day, option.costUsd);
      day.freeHours = Math.max(0, 14 - (day.activityHours + day.transferHours));

      if (ACTIVITIES[day.activityId]) {
        const activity = ACTIVITIES[day.activityId];
        const variant = activity.variants[day.selectedVariantKey] ? { key: day.selectedVariantKey, ...activity.variants[day.selectedVariantKey] } : chooseVariant(activity, STATE.plan.meta.budget);
        day.recommendation = buildRecommendation(activity, variant, {
          transferLabel: day.selectedTransferLabel,
          transferNote: option.note,
          lodging: day.lodging
        });
        day.warning = buildWarning(activity, variant, day.dayNumber, style, { transferHours: day.transferHours });
      }
    }

    function recalcDayCost(day, newTransferCost) {
      const activityCost = ACTIVITIES[day.activityId]?.variants?.[day.selectedVariantKey]?.costUsd || 0;
      return activityCost + (newTransferCost || 0);
    }

    function rebalancePlan(plan) {
      for (let i = 0; i < plan.days.length; i++) {
        const day = plan.days[i];
        if (!day.warning) day.warning = "";
      }

      for (let i = 0; i < plan.days.length - 1; i++) {
        const day = plan.days[i];
        if (day.transferHours + day.activityHours > 13) {
          const next = plan.days[i + 1];
          const extra = "El día anterior quedó pesado. Considera bajar exigencia o salir más tarde.";
          next.warning = next.warning ? `${next.warning} ${extra}` : extra;
        }
      }

      for (let i = 1; i < plan.days.length; i++) {
        const prev = plan.days[i - 1];
        const current = plan.days[i];
        if (prev.lodging === "aguas_calientes" && current.activityId === "machu_picchu") {
          current.recommendation += " Ya sales desde Aguas Calientes, así que este orden reduce fricción.";
        }
      }
    }

    function updateDayVariant(dayNumber, variantKey) {
      const plan = clone(STATE.plan);
      const day = plan.days.find(d => d.dayNumber === dayNumber);
      if (!day) return;
      applyVariantToDay(day, day.activityId, variantKey, plan.meta.style);
      rebalancePlan(plan);
      saveHistory(plan);
      renderPlan(plan);
    }

    function updateDayTransfer(dayNumber, transferKey) {
      const plan = clone(STATE.plan);
      const day = plan.days.find(d => d.dayNumber === dayNumber);
      if (!day) return;
      applyTransferToDay(day, transferKey, plan.meta.style);
      rebalancePlan(plan);
      saveHistory(plan);
      renderPlan(plan);
    }

    function inferTransferForActivity(activityId) {
      if (activityId === "machu_picchu") return "aguas_to_machu";
      if (activityId === "aguas_free") return "ollantaytambo_to_aguas";
      if (activityId === "santa_teresa") return "cusco_to_santa_teresa";
      return null;
    }

    function inferLodgingForActivity(activityId) {
      if (activityId === "aguas_free") return "aguas_calientes";
      if (activityId === "machu_picchu") return "cusco";
      if (activityId === "santa_teresa") return "santa_teresa";
      return "cusco";
    }

    function updateDayActivity(dayNumber, activityId) {
      const plan = clone(STATE.plan);
      const day = plan.days.find(d => d.dayNumber === dayNumber);
      if (!day) return;

      if (activityId === "free") {
        applyVariantToDay(day, "free", "", plan.meta.style);
      } else {
        const activity = ACTIVITIES[activityId];
        const variant = chooseVariant(activity, plan.meta.budget);
        day.selectedTransferId = inferTransferForActivity(activityId);
        day.selectedTransferKey = day.selectedTransferId ? plan.meta.budget : null;
        if (day.selectedTransferId && TRANSFERS[day.selectedTransferId]) {
          const transfer = TRANSFERS[day.selectedTransferId];
          day.selectedTransferLabel = `${transfer.label} • ${transfer.options[plan.meta.budget].label}`;
        } else {
          day.selectedTransferLabel = null;
        }
        day.lodging = inferLodgingForActivity(activityId);
        applyVariantToDay(day, activityId, variant.key, plan.meta.style);
      }

      rebalancePlan(plan);
      saveHistory(plan);
      renderPlan(plan);
    }

    function generarPlan() {
      const plan = createPlan();
      rebalancePlan(plan);
      saveHistory(plan);
      renderPlan(plan);
      document.getElementById("result-section").scrollIntoView({ behavior: "smooth", block: "start" });
    }

    function undoPlan() {
      if (STATE.historyIndex <= 0) return;
      STATE.historyIndex -= 1;
      STATE.plan = clone(STATE.history[STATE.historyIndex]);
      renderPlan(STATE.plan);
    }

    function redoPlan() {
      if (STATE.historyIndex >= STATE.history.length - 1) return;
      STATE.historyIndex += 1;
      STATE.plan = clone(STATE.history[STATE.historyIndex]);
      renderPlan(STATE.plan);
    }

    window.generarPlan = generarPlan;
    window.undoPlan = undoPlan;
    window.redoPlan = redoPlan;
  </script>
</body>
